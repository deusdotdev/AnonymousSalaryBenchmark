# Copy to .env.local and fill in values

# WalletConnect / Reown project id (optional; MetaMask works without it)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Sepolia RPC — Alchemy recommended for Explore event scans (getLogs)
# https://dashboard.alchemy.com → Apps → Sepolia → HTTPS URL
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Deployed SalaryFHE contract on Sepolia (optional — falls back to src/abi/deployment.json)
NEXT_PUBLIC_SALARY_FHE_ADDRESS=
